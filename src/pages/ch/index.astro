---
import PageLayout from '../../layouts/PageLayout.astro';
import { researchThemes } from '../../data/research';
import { publications } from '../../data/publications';
import { newsItems } from '../../data/news';

const featuredPubs = publications.filter(p => p.selected);
const featuredNews = newsItems.filter(n => n.featured).slice(0, 2);

const projectLinks: Record<string, string> = {
  'lai-2026-plos':    '/ch/research/emit2/',
  'lai-2024-ebiomed': '/ch/research/aerosol-shedding/',
};
---

<PageLayout
  title="赖建妤"
  description="流行病学家，研究呼吸道病原体通过呼出气体传播的机制——以及通风、口罩与行为干预如何阻断传播。"
  lang="zh"
>

  <!-- ============================================================
       Hero
       ============================================================ -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">博士后研究员 &nbsp;&middot;&nbsp; 马里兰大学 PHAB 实验室</p>

      <h1 class="hero-name">
        Jianyu Lai
        <span class="hero-cjk">赖建妤</span>
      </h1>

      <p class="hero-tagline">
        流行病学家，研究呼吸道病原体如何通过呼出气体传播——
        以及通风、口罩和行为干预如何阻断传播。
      </p>

      <div class="hero-cta">
        <a href="/ch/research/"     class="btn btn-primary">探索研究</a>
        <a href="/ch/publications/" class="btn btn-ghost-light">论文</a>
        <a href="/ch/about/"        class="btn btn-ghost-light">关于</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Research themes
       ============================================================ -->
  <section class="section bg-alt">
    <div class="container">

      <header class="section-header">
        <p class="eyebrow">研究</p>
        <h2>研究方向</h2>
      </header>

      <ul class="research-list">
        {researchThemes.map(theme => (
          <li class="research-list-item">
            <div class="research-list-bar" style={`background: ${theme.accentColor}`}></div>
            <div class="research-list-body">
              <p class="research-list-title">
                {theme.hasProjectPage
                  ? <a href={`/ch/research/${theme.slug}/`}>{theme.title_zh ?? theme.title}</a>
                  : (theme.title_zh ?? theme.title)
                }
              </p>
              <p class="research-list-summary">{theme.summary_zh ?? theme.summary}</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="section-more">
        <a href="/ch/research/" class="btn btn-outline">全部研究 &rarr;</a>
      </div>

    </div>
  </section>

  <!-- ============================================================
       Featured publications
       ============================================================ -->
  {featuredPubs.length > 0 && (
    <section class="section">
      <div class="container">

        <header class="section-header">
          <p class="eyebrow">精选成果</p>
          <h2>重点论文</h2>
        </header>

        <div class="featured-pub-list">
          {featuredPubs.map(pub => (
            <article class="featured-pub">
              <div class="featured-pub-meta">
                <span class="featured-pub-journal">{pub.journal}</span>
                <span class="featured-pub-year">{pub.year}</span>
                {pub.pressMentionIds && pub.pressMentionIds.length > 0 && (
                  <span class="featured-pub-press-badge">
                    {pub.pressMentionIds.length} 篇媒体报道
                  </span>
                )}
              </div>
              <h3 class="featured-pub-title">
                <a href={pub.url} target="_blank" rel="noopener noreferrer">
                  {pub.title}
                </a>
              </h3>
              <p class="featured-pub-authors">{pub.authors}</p>
              {pub.selectedSummary_zh && (
                <p class="featured-pub-summary">{pub.selectedSummary_zh}</p>
              )}
              <div class="featured-pub-actions">
                <a href={pub.url} target="_blank" rel="noopener noreferrer" class="featured-pub-link">
                  阅读论文 →
                </a>
                {projectLinks[pub.id] && (
                  <a href={projectLinks[pub.id]} class="featured-pub-link featured-pub-link--muted">
                    查看项目 →
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>

        <div class="section-more">
          <a href="/ch/publications/" class="btn btn-outline">全部论文 &rarr;</a>
        </div>

      </div>
    </section>
  )}

  <!-- ============================================================
       News teaser
       ============================================================ -->
  {featuredNews.length > 0 && (
    <section class="section bg-alt">
      <div class="container">

        <header class="section-header">
          <p class="eyebrow">媒体报道</p>
          <h2>新闻报道</h2>
        </header>

        <div class="news-list">
          {featuredNews.map(item => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-item">
              <div class="news-item-left">
                <span class="news-outlet">{item.outlet}</span>
                <span class="news-year">{item.year}</span>
              </div>
              <div class="news-item-right">
                <p class="news-headline">{item.headline}</p>
                <p class="news-context">{item.context_zh ?? item.context}</p>
              </div>
              <span class="news-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>

        <div class="section-more">
          <a href="/ch/news/" class="btn btn-outline">全部报道 &rarr;</a>
        </div>

      </div>
    </section>
  )}

</PageLayout>

<style>
  /* ==============================================
     Hero
     ============================================== */
  .hero {
    background: var(--color-navy);
    padding: var(--space-24) 0 var(--space-20);
  }

  .hero-eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 var(--space-6);
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-2);
  }

  .hero-cjk {
    display: inline;
    font-weight: 400;
    font-style: italic;
    font-size: 0.55em;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.1em;
    margin-left: var(--space-3);
    vertical-align: middle;
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.62);
    max-width: 540px;
    line-height: 1.7;
    margin: var(--space-6) 0 var(--space-10);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ==============================================
     Section helpers
     ============================================== */
  .bg-alt {
    background: var(--color-surface-alt);
  }

  .section-header {
    margin-bottom: var(--space-10);
    max-width: 640px;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin: 0 0 var(--space-2);
  }

  .section-header h2 {
    margin: 0 0 var(--space-3);
  }

  .section-more {
    margin-top: var(--space-8);
  }

  /* ==============================================
     Research list
     ============================================== */
  .research-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 600px) {
    .research-list { grid-template-columns: 1fr; }
  }

  .research-list-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .research-list-bar {
    flex-shrink: 0;
    width: 3px;
    align-self: stretch;
    border-radius: 2px;
  }

  .research-list-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .research-list-title {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--color-navy);
    margin: 0;
  }

  .research-list-title a {
    color: var(--color-navy);
    text-decoration: none;
  }

  .research-list-title a:hover {
    color: var(--color-teal);
  }

  .research-list-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ==============================================
     Featured publications
     ============================================== */
  .featured-pub-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .featured-pub {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .featured-pub:first-child {
    border-top: 1px solid var(--color-border-light);
  }

  .featured-pub-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .featured-pub-journal {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-teal-dim);
  }

  .featured-pub-year {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .featured-pub-press-badge {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .featured-pub-title {
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--color-navy);
    margin: 0;
  }

  .featured-pub-title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-pub-title a:hover {
    color: var(--color-teal-dim);
  }

  .featured-pub-authors {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .featured-pub-summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .featured-pub-actions {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    margin-top: var(--space-1);
  }

  .featured-pub-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-teal);
    text-decoration: none;
  }

  .featured-pub-link:hover {
    text-decoration: underline;
  }

  .featured-pub-link--muted {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  /* ==============================================
     News teaser
     ============================================== */
  .news-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .news-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .news-item:hover {
    box-shadow: var(--shadow-sm);
    border-color: rgba(0, 0, 0, 0.14);
    text-decoration: none;
  }

  .news-item-left {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-1);
    min-width: 120px;
  }

  .news-outlet {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-teal-dim);
  }

  .news-year {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .news-item-right {
    flex: 1;
  }

  .news-headline {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-navy);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-1);
  }

  .news-context {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .news-arrow {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 560px) {
    .news-item { flex-wrap: wrap; }
    .news-item-left { flex-direction: row; gap: var(--space-3); min-width: auto; }
    .news-arrow { display: none; }
  }
</style>
