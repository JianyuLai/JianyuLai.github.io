---
import PageLayout from '../layouts/PageLayout.astro';
import ResearchCard from '../components/research/ResearchCard.astro';
import { researchThemes } from '../data/research';
import { publications } from '../data/publications';
import { newsItems } from '../data/news';

const featuredPub  = publications.find(p => p.id === 'lai-2026-plos');
const featuredNews = newsItems.filter(n => n.featured).slice(0, 2);
---

<PageLayout title="Jianyu Lai">

  <!-- ============================================================
       Hero
       ============================================================ -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Postdoctoral Associate &nbsp;&middot;&nbsp; UMD PHAB Lab</p>

      <h1 class="hero-name">
        Jianyu Lai
        <span class="hero-cjk">赖建妤</span>
      </h1>

      <p class="hero-tagline">
        Epidemiologist studying how respiratory pathogens spread through exhaled breath —
        and how ventilation, masks, and behavior can stop them.
      </p>

      <div class="hero-cta">
        <a href="/research/"     class="btn btn-primary">Explore Research</a>
        <a href="/publications/" class="btn btn-ghost-light">Publications</a>
        <a href="/about/"        class="btn btn-ghost-light">About</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Research themes
       ============================================================ -->
  <section class="section bg-alt">
    <div class="container">

      <header class="section-header">
        <p class="eyebrow">Research</p>
        <h2>Areas of Investigation</h2>
        <p class="section-desc">
          My work connects rigorous epidemiologic methods with laboratory data and
          exposure science to understand how respiratory infections spread and how
          transmission can be interrupted.
        </p>
      </header>

      <div class="research-grid">
        {researchThemes.map(theme => (
          <ResearchCard theme={theme} />
        ))}
      </div>

      <div class="section-more">
        <a href="/research/" class="btn btn-outline">All Research &rarr;</a>
      </div>

    </div>
  </section>

  <!-- ============================================================
       Featured publication
       ============================================================ -->
  {featuredPub && (
    <section class="section">
      <div class="container">

        <header class="section-header">
          <p class="eyebrow">Signature Work</p>
          <h2>Featured Publication</h2>
        </header>

        <article class="featured-pub">
          <div class="featured-pub-meta">
            <span class="featured-pub-journal">{featuredPub.journal}</span>
            <span class="featured-pub-year">{featuredPub.year}</span>
            {featuredPub.pressMentionIds && featuredPub.pressMentionIds.length > 0 && (
              <span class="featured-pub-press-badge">
                📰 {featuredPub.pressMentionIds.length} press mentions
              </span>
            )}
          </div>

          <h3 class="featured-pub-title">
            <a href={featuredPub.url} target="_blank" rel="noopener noreferrer">
              {featuredPub.title}
            </a>
          </h3>

          <p class="featured-pub-authors">{featuredPub.authors}</p>

          {featuredPub.selectedSummary && (
            <p class="featured-pub-summary">{featuredPub.selectedSummary}</p>
          )}

          <div class="featured-pub-actions">
            <a
              href={featuredPub.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              Read Paper →
            </a>
            <a href="/research/emit2/" class="btn btn-outline">
              View Project
            </a>
          </div>
        </article>

      </div>
    </section>
  )}

  <!-- ============================================================
       News teaser
       ============================================================ -->
  {featuredNews.length > 0 && (
    <section class="section bg-alt">
      <div class="container">

        <header class="section-header">
          <p class="eyebrow">Media Coverage</p>
          <h2>In the News</h2>
        </header>

        <div class="news-list">
          {featuredNews.map(item => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-item">
              <div class="news-item-left">
                <span class="news-outlet">{item.outlet}</span>
                <span class="news-year">{item.year}</span>
              </div>
              <div class="news-item-right">
                <p class="news-headline">{item.headline}</p>
                <p class="news-context">{item.context}</p>
              </div>
              <span class="news-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>

        <div class="section-more">
          <a href="/news/" class="btn btn-outline">All Coverage &rarr;</a>
        </div>

      </div>
    </section>
  )}

</PageLayout>

<style>
  /* ==============================================
     Hero
     ============================================== */
  .hero {
    background: var(--color-navy);
    padding: var(--space-24) 0 var(--space-20);
  }

  .hero-eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 var(--space-6);
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-2);
  }

  .hero-cjk {
    display: inline;
    font-weight: 400;
    font-style: italic;
    font-size: 0.55em;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.1em;
    margin-left: var(--space-3);
    vertical-align: middle;
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.62);
    max-width: 540px;
    line-height: 1.7;
    margin: var(--space-6) 0 var(--space-10);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ==============================================
     Section helpers
     ============================================== */
  .bg-alt {
    background: var(--color-surface-alt);
  }

  .section-header {
    margin-bottom: var(--space-10);
    max-width: 640px;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin: 0 0 var(--space-2);
  }

  .section-header h2 {
    margin: 0 0 var(--space-3);
  }

  .section-desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .section-more {
    margin-top: var(--space-8);
  }

  /* ==============================================
     Research card grid
     ============================================== */
  .research-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 900px) {
    .research-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .research-grid { grid-template-columns: 1fr; }
  }

  /* ==============================================
     Featured publication
     ============================================== */
  .featured-pub {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }

  .featured-pub-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border-light);
  }

  .featured-pub-journal {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .featured-pub-year {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .featured-pub-press-badge {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-left: auto;
  }

  .featured-pub-title {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, var(--text-2xl));
    font-weight: 700;
    line-height: var(--leading-snug);
    color: var(--color-navy);
    margin: 0 0 var(--space-3);
    letter-spacing: -0.01em;
  }

  .featured-pub-title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-pub-title a:hover {
    color: var(--color-teal-dim);
    text-decoration: none;
  }

  .featured-pub-authors {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .featured-pub-summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-style: italic;
    margin: 0 0 var(--space-7);
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-border);
  }

  .featured-pub-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ==============================================
     News teaser
     ============================================== */
  .news-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .news-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .news-item:hover {
    box-shadow: var(--shadow-sm);
    border-color: rgba(0, 0, 0, 0.14);
    text-decoration: none;
  }

  .news-item-left {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-1);
    min-width: 120px;
  }

  .news-outlet {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-teal-dim);
  }

  .news-year {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .news-item-right {
    flex: 1;
  }

  .news-headline {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-navy);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-1);
  }

  .news-context {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .news-arrow {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 560px) {
    .news-item { flex-wrap: wrap; }
    .news-item-left { flex-direction: row; gap: var(--space-3); min-width: auto; }
    .news-arrow { display: none; }
  }
</style>
