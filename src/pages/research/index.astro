---
import PageLayout from '../../layouts/PageLayout.astro';
import ResearchCard from '../../components/research/ResearchCard.astro';
import { researchThemes } from '../../data/research';
import { publications } from '../../data/publications';

// Aggregate total publication count for the page subtitle
const totalPubs = publications.filter(p => p.type === 'peer-reviewed').length;
---

<PageLayout
  title="Research"
  description="Research on airborne transmission of respiratory viruses, exhaled breath aerosol shedding, ventilation, and measurement methods."
>

  <!-- Page hero -->
  <div class="page-hero">
    <div class="container">
      <span class="page-hero-label">Scholarly Work</span>
      <h1>Research</h1>
      <p class="page-hero-lead">
        My work spans controlled transmission trials, aerosol shedding experiments, and
        observational cohort research — connecting epidemiologic methods with laboratory
        science to understand how respiratory pathogens spread.
      </p>
    </div>
  </div>

  <!-- Research theme grid -->
  <section class="section">
    <div class="container">

      <div class="research-grid">
        {researchThemes.map(theme => (
          <ResearchCard theme={theme} />
        ))}
      </div>

    </div>
  </section>

</PageLayout>

<style>
  /* Research card grid — 2 columns on desktop, 1 on mobile */
  .research-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 760px) {
    .research-grid { grid-template-columns: 1fr; }
  }

  /* Approach section */
  .approach-section {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border-light);
  }

  .approach-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
    color: var(--color-navy);
  }

  .approach-section p {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 680px;
    margin-bottom: var(--space-4);
  }

  .approach-inner {
    max-width: 720px;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }
</style>
