---
const year = new Date().getFullYear();

const externalLinks = [
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=JUXhqcEAAAAJ&hl=en',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/jianyu-lai/',
  },
  {
    label: 'Email',
    href: 'mailto:jlai12@umd.edu',
  },
];
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-identity">
      <p class="footer-name">Jianyu Lai <span class="footer-cjk">赖建妤</span></p>
      <p class="footer-affiliation">
        Postdoctoral Associate &middot; Public Health AeroBiology Laboratory<br />
        University of Maryland, College Park
      </p>
    </div>

    <div class="footer-right">
      <nav class="footer-links" aria-label="External links">
        {externalLinks.map(link => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="footer-link"
          >
            {link.label}
          </a>
        ))}
      </nav>
      <p class="footer-copy">&copy; {year} Jianyu Lai</p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy-dim);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: var(--space-12) 0 var(--space-8);
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  /* Identity */
  .footer-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 var(--space-2);
  }

  .footer-cjk {
    font-weight: 400;
    font-style: italic;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.85em;
    margin-left: var(--space-1);
  }

  .footer-affiliation {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.45);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* Right side */
  .footer-right {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
  }

  .footer-links {
    display: flex;
    gap: var(--space-5);
  }

  .footer-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.58);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-teal-light);
    text-decoration: none;
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.28);
    margin: 0;
  }

  @media (max-width: 640px) {
    .footer-right {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
