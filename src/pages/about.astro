---
import PageLayout from '../layouts/PageLayout.astro';
import { timelineSorted } from '../data/timeline';

// Icon map for timeline event types
const typeIcon: Record<string, string> = {
  position:    '●',
  education:   '◆',
  publication: '▲',
  media:       '★',
  award:       '✦',
};

const typeLabel: Record<string, string> = {
  position:    'Position',
  education:   'Education',
  publication: 'Publication',
  media:       'Media',
  award:       'Award',
};
---

<PageLayout
  title="About"
  description="About Jianyu Lai — postdoctoral researcher in public health aerobiology and respiratory virus epidemiology."
>

  <!-- Page hero -->
  <div class="page-hero">
    <div class="container">
      <span class="page-hero-label">Background</span>
      <h1>About</h1>
      <p class="page-hero-lead">
        Postdoctoral Associate at the Public Health AeroBiology Laboratory,
        University of Maryland, College Park.
      </p>
    </div>
  </div>

  <div class="section container">
    <div class="about-grid">

      <!-- Bio column -->
      <div class="about-bio">

        <section class="about-section">
          <h2>Current Position</h2>
          <div class="position-card">
            <p class="position-title">Postdoctoral Associate</p>
            <p class="position-lab">Public Health AeroBiology Laboratory (PHAB Lab)</p>
            <p class="position-dept">Department of Global, Environmental, and Occupational Health</p>
            <p class="position-school">School of Public Health, University of Maryland, College Park</p>
          </div>
        </section>

        <section class="about-section">
          <h2>Education</h2>
          <ul class="education-list">
            <li>
              <span class="edu-degree">PhD, Epidemiology</span>
              <span class="edu-inst">University of Maryland, College Park</span>
            </li>
            <li>
              <span class="edu-degree">MPH, Epidemiology</span>
              <span class="edu-inst">University of Michigan, Ann Arbor</span>
            </li>
            <li>
              <span class="edu-degree">Graduate Certificate, Health Informatics</span>
              <span class="edu-inst">University of Michigan, Ann Arbor</span>
            </li>
            <li>
              <span class="edu-degree">BMed, Preventive Medicine</span>
              <span class="edu-inst">Sun Yat-sen University</span>
            </li>
          </ul>
        </section>

        <section class="about-section">
          <h2>Contact</h2>
          <ul class="contact-list">
            <li>
              <a href="mailto:jlai12@umd.edu">jlai12@umd.edu</a>
            </li>
            <li>
              <a href="https://scholar.google.com/citations?user=JUXhqcEAAAAJ&hl=en" target="_blank" rel="noopener">
                Google Scholar
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/in/jianyu-lai/" target="_blank" rel="noopener">
                LinkedIn
              </a>
            </li>
          </ul>
        </section>

      </div>

      <!-- Timeline column -->
      <div class="about-timeline">
        <h2 class="timeline-heading">Experience</h2>

        {timelineSorted.length > 0 ? (
          <ol class="timeline">
            {timelineSorted.map(event => (
              <li class="timeline-event" data-type={event.type}>
                <div class="timeline-marker" title={typeLabel[event.type] ?? event.type}>
                  {typeIcon[event.type] ?? '●'}
                </div>
                <div class="timeline-content">
                  <span class="timeline-year">{event.year}</span>
                  <p class="timeline-title">{event.title}</p>
                  {event.institution && (
                    <p class="timeline-institution">{event.institution}</p>
                  )}
                  {event.description && (
                    <p class="timeline-desc">{event.description}</p>
                  )}
                </div>
              </li>
            ))}
          </ol>
        ) : (
          <div class="placeholder-block">
            Career timeline — populated in next step
          </div>
        )}
      </div>

    </div>
  </div>
</PageLayout>

<style>
  /* About grid layout */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Sections */
  .about-section {
    margin-bottom: var(--space-10);
  }

  .about-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  /* Position card */
  .position-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-teal);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
  }

  .position-title {
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-navy);
    margin-bottom: var(--space-1);
  }

  .position-lab,
  .position-dept,
  .position-school {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .position-school { margin-bottom: 0; }

  /* Education list */
  .education-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .education-list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-border);
  }

  .edu-degree {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-navy);
  }

  .edu-inst {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Contact list */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-list a {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  /* Timeline */
  .timeline-heading {
    font-size: var(--text-xl);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  /* Vertical line */
  .timeline::before {
    content: '';
    position: absolute;
    left: 0.6rem;
    top: 0;
    bottom: 0;
    width: 1.5px;
    background: var(--color-border);
  }

  .timeline-event {
    display: flex;
    gap: var(--space-5);
    padding-bottom: var(--space-8);
    position: relative;
  }

  .timeline-event:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    color: var(--color-teal);
    background: var(--color-cream);
    border: 2px solid var(--color-teal);
    border-radius: 50%;
    position: relative;
    z-index: 1;
    margin-top: 2px;
  }

  .timeline-event[data-type="education"] .timeline-marker {
    border-color: #3a7ca5;
    color: #3a7ca5;
  }

  .timeline-event[data-type="publication"] .timeline-marker {
    border-color: var(--color-navy);
    color: var(--color-navy);
  }

  .timeline-year {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-1);
  }

  .timeline-title {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--color-navy);
    margin-bottom: var(--space-1);
  }

  .timeline-institution {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .timeline-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--leading-relaxed);
  }
</style>
